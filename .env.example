# Активные интерфейсы (через запятую): telegram, web.
#   telegram — бот в группе с форум-топиками (нужен TELEGRAM_BOT_TOKEN);
#   web      — локальный веб-интерфейс (см. WEB_* ниже).
# Работают и вместе: одна сессия видна из обоих.
# ADAPTERS=telegram

# Модули (через запятую). wallet — кошелёк секретов: токены для CLI-тулз
# (gh, kubectl…) без доступа модели к значениям (см. docs/secrets-wallet.md).
# По умолчанию (переменная НЕ задана) при SANDBOX=bwrap кошелёк ВКЛЮЧЁН —
# host-like работа с gh/git/ssh без выдачи секретов модели. Задай пустым
# (MODULES=) чтобы отключить, или перечисли модули явно.
# MODULES=wallet

# Токен бота (от @BotFather). Обязателен при ADAPTERS с telegram.
TELEGRAM_BOT_TOKEN=your_token_here

# ID группы с включёнными Topics (бот должен быть админом).
# Узнать ID: добавь бота в группу и отправь /chat_id — он покажет ID
# и привяжется. Если не задан — привязка к первому чату с сообщением,
# но лучше зафиксировать явно.
# TELEGRAM_CHAT_ID=-1001234567890

# Кому разрешено пользоваться ботом (Telegram user id через запятую).
# Обязательно: пустой список = бот игнорирует все сообщения.
ALLOWED_USER_IDS=123456789

# Веб-интерфейс (ADAPTERS=…,web): адрес и токен доступа.
# Токен пуст — генерируется на пуск, URL с токеном печатается в лог (как Jupyter).
# Наружу (не 127.0.0.1) выставлять только за reverse-proxy с TLS.
# WEB_HOST=127.0.0.1
# WEB_PORT=8180
# WEB_TOKEN=__long_random_string__

# Кошелёк секретов (MODULES=wallet): TOML-файл секретов и политик, права 0600.
# Формат — docs/secrets-wallet.md. Файл лежит ВНЕ песочницы (модель его не видит).
# Если файла нет — создаётся автоматически при первом запуске с дефолтом «из
# коробки»: прокол на хост gh/git/ssh/scp для всех сессий (обёртки в PATH).
# ВАЖНО: кошелёк страхует ТОЛЬКО в связке с SANDBOX=bwrap (без песочницы модель
# читает секреты напрямую — при старте будет громкое предупреждение в логах).
# WALLET_SECRETS_FILE=~/.config/claude-orchestrator/secrets.toml
# Встроенный всегда-запрет опасного (печать токена gh auth token, git-RCE через
# флаги) поверх policy; 0 — выключить (модель сможет что угодно в рамках commands).
# WALLET_GUARD=1
# Правка policy кошелька из чата (команда /wallet). По умолчанию включено;
# 0 — только просмотр, правки лишь host-файлом secrets.toml.
# WALLET_POLICY_EDIT=1
# Судья auto-режима Claude Code проверяет ВСЕ bash-команды (не только «на вид
# рискованные») — чтобы хитрый secret-exfil не проскочил. Только при wallet+bwrap+
# PERMISSION_MODE=auto. 0 — меньше вопросов (напр. на force-push), слабее защита.
# AUTOMODE_CLASSIFY_ALL_SHELL=1

# Пул портов channel-серверов (по одному на сессию).
# Не задано — авто: ОС сама выдаёт свободный localhost-порт на сессию
# (не нужно настраивать пул и нельзя исчерпать). Задавай диапазон явно,
# только если нужны предсказуемые порты (файрвол, отладка).
# CHANNEL_PORT_START=18761
# CHANNEL_PORT_END=18770

# Директория для сессий (cwd Claude)
# SESSIONS_DIR=~/tg-claude-sessions

# Максимум одновременных сессий
# MAX_INSTANCES=5

# Путь к бинарнику Claude Code
# CLAUDE_BIN=claude

# Модель по умолчанию для всех новых сессий (псевдоним fable/opus/sonnet/haiku
# или точное имя, напр. claude-opus-4-8). Не задано — Claude берёт свой дефолт
# (или то, что в профиле/проекте). Команда /model на сессию перекрывает это.
# DEFAULT_MODEL=opus

# Effort (уровень размышления) по умолчанию: low/medium/high/xhigh/max.
# Не задано — Claude/профиль/проект решают сами.
# DEFAULT_EFFORT=high

# Свой профиль Claude Code вместо ~/.claude (конфиг, авторизация, история)
# CLAUDE_CONFIG_DIR=~/.claude-bot

# Проброс произвольных env в процесс claude: префикс CLAUDE_ENV_<ИМЯ>=<знач>
# уходит в claude как <ИМЯ>=<знач>. Например — свой Anthropic-эндпоинт/токен:
# CLAUDE_ENV_ANTHROPIC_BASE_URL=https://my-proxy.example.com
# CLAUDE_ENV_ANTHROPIC_AUTH_TOKEN=sk-...

# HTTP-порт оркестратора для приёма ответов от channel-серверов
# ORCH_PORT=18080

# Общий секрет внутреннего HTTP-API оркестратора (защита 127.0.0.1-эндпоинтов
# /reply /event /permission от любого локального процесса и DNS-rebinding).
# Channel-сервер и PreToolUse-хук пробрасывают его сами. Не задано — бот
# генерирует разовый токен на пуск (логируется WARNING); для стабильности
# между перезапусками зафиксируй тут.
# ORCH_TOKEN=__long_random_string__
# systemd-юнит для команды /orchestrator_restart (self-restart). Пусто →
# авто-детект из /proc/self/cgroup, фолбэк claude-orchestrator.service.
# ORCH_SYSTEMD_UNIT=claude-orchestrator.service

# Показывать вызовы инструментов Claude в статус-бабле (PreToolUse-хук)
# SHOW_TOOL_CALLS=true

# Удалять статус-бабл после финального ответа.
# false — бабл остаётся в топике как журнал работы (без кнопки Стоп).
# DELETE_BUBBLE=true

# Меню команд (кнопка «/» в поле ввода). В группе Telegram всё равно показывает
# «/команда@ботusername» — это клиентский роутинг, API это не убрать. false
# скрывает меню целиком (команды печатаются вручную). true по умолчанию.
# SHOW_COMMAND_MENU=true

# Режим разрешений Claude:
#   auto        — классификатор решает; запросы приходят в Telegram кнопками ✅/❌
#   bypass      — без ограничений (--dangerously-skip-permissions)
#   acceptEdits — правки файлов без вопросов, остальное спрашивает
#   manual      — спрашивать всё неразрешённое
#   dontAsk     — запрещать всё неразрешённое, не спрашивая
#   plan        — только чтение, правки спрашивает
# PERMISSION_MODE=auto

# Файловая песочница (bubblewrap). ВКЛЮЧЕНА по умолчанию.
#   bwrap — процесс claude и /bash-терминал заперты в mount-namespace: видят
#           ТОЛЬКО папку сессии/проекта и конфиг Claude Code (CLAUDE_CONFIG_DIR
#           + ~/.claude.json: токены, скиллы, plugins, транскрипты) на запись,
#           а бинарь claude и репозиторий оркестратора — на чтение. Весь
#           остальной $HOME (другие проекты, ~/.ssh, ~/.aws) и система скрыты.
#           Накрывает ВСЕ инструменты сразу (Read/Write/Edit, Bash, MCP, хуки),
#           в отличие от нативного /sandbox (тот ограничивает только Bash).
#           Сеть общая с хостом (нужна для API и оркестратора) — фильтрации по
#           доменам нет. Требует bubblewrap (apt install bubblewrap) и разрешён-
#           ных unprivileged user namespaces. Если недоступно — бот не стартует.
#           Дом сессии персистентный: SESSIONS_DIR/.homes/<имя> монтируется как
#           $HOME — venv/кэши агента переживают рестарты.
#   agent-vm — microVM через wirenboard/agent-vm (нужен KVM). ЭКСПЕРИМЕНТАЛЬНО,
#           см. docs/agent-vm-integration.md; ресурсы — AGENT_VM_* ниже.
#   off   — без изоляции: claude имеет доступ ко всей ФС (как раньше). Нужно на
#           машинах без bwrap/userns. МЕНЕЕ БЕЗОПАСНО.
# SANDBOX=bwrap

# Ресурсы и образ microVM для SANDBOX=agent-vm (пин образа полезен: гостевые
# образы пересобираются ежечасно и могут уехать от research-preview флагов).
# AGENT_VM_MEMORY_GIB=8
# AGENT_VM_CPUS=4
# AGENT_VM_IMAGE=ghcr.io/wirenboard/agent-vm-template:tag

# Доп. пути, открытые из песочницы на ЗАПИСЬ (через ':', как $PATH). Для рабочих
# каталогов вне папки сессии/проекта — общий кэш сборки, каталог с данными и т.п.
# SANDBOX_EXTRA_RW=/srv/shared:~/datasets

# Проброс system D-Bus в песочницу (SANDBOX=bwrap). Главный юзкейс — mDNS/
# локальная сеть: .local-хосты и обзор сервисов (avahi-browse, DNS-SD) идут
# через system D-Bus, где зарегистрирован Avahi. true (по умолчанию) —
# пробросить. ⚠️ Открывает ВЕСЬ system D-Bus (systemd, logind, NetworkManager,
# Avahi…), не только mDNS: read-методы работают, мутации остаются под polkit.
# off — запретить (обычный DNS и базовый .local-резолв хоста остаются — они
# работают без D-Bus, через multicast).
# SANDBOX_DBUS=true

# Проброс X/Wayland в песочницу (SANDBOX=bwrap). Сеть у песочницы общая с хостом,
# поэтому абстрактный сокет X-сервера достижим даже при tmpfs /tmp — с $DISPLAY
# процесс в песочнице мог бы дёрнуть хостовый GUI (askpass-диалоги, скриншоты,
# перехват ввода). По умолчанию X ВЫРЕЗАН (убираются DISPLAY/XAUTHORITY/
# WAYLAND_DISPLAY) — CLI-режиму X не нужен. Раскомментируй, если модели реально
# нужен графический дисплей в песочнице.
# SANDBOX_X11=1

# ВАЖНО про bwrap и $HOME: под bwrap $HOME процесса claude подменён приватным
# персистентным домом сессии (SESSIONS_DIR/.homes/<имя>), поэтому реальный
# ~/.venv и глобальные инструменты из твоего дома НЕ видны — это изоляция.
# Держи окружение проекта В ПРОЕКТЕ (python -m venv .venv в папке проекта — она
# смонтирована RW и переживает рестарты). venv в ~ сессии тоже переживёт
# рестарты (дом персистентный), но проект чище.

# Хост, на котором channel-серверы ищут оркестратор (менять не нужно)
# ORCH_HOST=127.0.0.1

# Язык сообщений бота: ru | en
# BOT_LANG=ru

# Авто-останов сессии после стольких часов простоя (топик и resume остаются).
# 0 — отключить. Проверка раз в 10 минут.
# IDLE_TIMEOUT_H=6

# Ротация claude.log: при превышении размера (МБ) лог сдвигается в .old.
# 0 — не ротировать.
# LOG_MAX_MB=10

# Куда сохранять присланные в Telegram файлы/фото.
# Относительный путь — внутри папки сессии, абсолютный — общий для всех.
# INCOMING_DIR=incoming
