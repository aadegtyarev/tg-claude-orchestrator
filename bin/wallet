#!/usr/bin/env python3
"""wallet — CLI кошелька секретов внутри сессии Claude Code.

Секретов здесь нет и не будет: CLI только шлёт команду демону оркестратора
(TCP-localhost, сеть у песочницы общая с хостом), тот исполняет её НА ХОСТЕ
с секретом в env и возвращает уже отредактированный вывод (значения секретов
заменены на •••). См. docs/secrets-wallet.md.

Использование:
    wallet ls                       — какие секреты доступны этой сессии
    wallet run <имя> -- <cmd ...>   — выполнить команду с секретом
    wallet get <имя>                — значение shared-секрета (dev-ключ, логин/пароль)
    wallet env <имя>                — shared-секрет как `export ENV=…` (для eval/.env)

Конфиг ищется в $WALLET_FILE, затем ~/.wallet.json (внутри песочницы
персистентный дом сессии смонтирован как $HOME — файл кладёт туда демон).
Только stdlib: работает в песочнице, где .venv недоступен.
"""

import json
import os
import sys
import urllib.error
import urllib.request

# Демон может ждать подтверждение (до 300с) И потом исполнять команду (до
# 300с) — суммарно до ~600с. Ставим потолок выше, чтобы CLI не отвалился по
# таймауту, пока команда с секретом ещё выполняется на хосте (иначе модель
# увидит «сбой» и повторит побочно-эффектную команду — двойной запуск).
HTTP_TIMEOUT = 660

# Полная справка (wallet help / -h) — модель может дёрнуть перед работой.
HELP = """wallet — использовать секреты, не видя их значений.

wallet УЖЕ в PATH — зови `wallet ...` (без полного пути). Команда бежит НА ХОСТЕ
в папке твоего проекта, поэтому `cd` в шелле на неё НЕ влияет и не нужен. Один
вызов = одна команда; НЕ оборачивай в while/poll-цикл (используй нативный --watch
инструмента внутри одного `wallet run`).

Команды:
  wallet ls                    какие секреты доступны (имя, режим, разрешённые команды)
  wallet run <имя> -- <cmd..>  выполнить команду с секретом
  wallet get <имя>             значение shared-секрета (dev-ключ, логин/пароль)
  wallet env <имя>             shared-секрет как `export ENV=..` (eval / .env сервиса)
  wallet help                  эта справка

Три режима (какой у секрета — видно в `wallet ls`):
  host    команда идёт с кредами хоста (gh/git/ssh и т.п.); значение тебе не нужно.
  inject  токен кладётся в env-переменную $ENV — gh/aws/kubectl читают её сами.
          Где значение нужно В КОМАНДЕ (curl-заголовок, ssh-ключ) — плейсхолдеры,
          их подставляет демон (значение к тебе не попадает):
            {{secret}}       в строку аргумента: curl -H "Authorization: Bearer {{secret}}"
            {{secret_file}}  во временный файл:  ssh -i {{secret_file}}
  shared  значение, которое ТЕБЕ можно получить (wallet get / wallet env).

Правила:
  - Кред, которого у тебя НЕТ (auth хоста, токен из списка) → только через wallet.
    НЕ строй свой путь авторизации (ssh-keyscan, gh auth login, токен в git-remote)
    — используй wallet run с секретом из `wallet ls`.
  - Кред, который у тебя УЖЕ есть (дал юзер, или свой ключ под новый ресурс) →
    используй напрямую, wallet не нужен.
  - Значения host/inject не выводятся (в выводе заменяются на •••); не пытайся их
    распечатать/трансформировать, чтобы увидеть — они тебе для этого не нужны.
  - Не смог (нет секрета в списке / отказ / не работает) → скажи оператору через
    reply_to_user (что делал, точную команду, ошибку), не изобретай обход."""


def die(msg: str, code: int = 2) -> "NoReturn":  # noqa: F821 — py3.10 без импорта
    print(f"wallet: {msg}", file=sys.stderr)
    sys.exit(code)


def load_config() -> dict:
    candidates = []
    if os.environ.get("WALLET_FILE"):
        candidates.append(os.environ["WALLET_FILE"])
    candidates.append(os.path.expanduser("~/.wallet.json"))
    for path in candidates:
        try:
            with open(path, encoding="utf-8") as f:
                cfg = json.load(f)
            if cfg.get("url") and cfg.get("token"):
                return cfg
        except (OSError, ValueError):
            continue
    die(
        "конфиг не найден (~/.wallet.json). Кошелёк не включён? "
        "На стороне оркестратора нужен MODULES=wallet в .env."
    )


def call(cfg: dict, method: str, path: str, payload: dict | None = None) -> dict:
    req = urllib.request.Request(
        cfg["url"] + path,
        data=json.dumps(payload).encode() if payload is not None else None,
        headers={
            "Authorization": "Bearer " + cfg["token"],
            "Content-Type": "application/json",
        },
        method=method,
    )
    try:
        with urllib.request.urlopen(req, timeout=HTTP_TIMEOUT) as resp:
            return json.loads(resp.read().decode())
    except urllib.error.HTTPError as e:
        try:
            body = json.loads(e.read().decode())
            reason, err = body.get("reason", ""), body.get("error", "")
        except Exception:
            reason, err = "", ""
        if e.code == 401:
            die("токен не принят — сессия пересоздана? перезапусти оркестратор")
        if e.code == 403:
            # reason (когда есть) прозрачно объясняет ЧТО не так и КАК правильно;
            # иначе — общий отказ policy/подтверждения.
            die(reason or "отказано: секрет не разрешён этой сессии/команде "
                "или отклонён кнопкой", 3)
        die(f"демон ответил {e.code}: {err}")
    except urllib.error.URLError as e:
        die(f"демон кошелька недоступен ({e.reason}) — оркестратор запущен с MODULES=wallet?")


def cmd_ls(cfg: dict) -> int:
    secrets = call(cfg, "GET", "/secrets")
    if not secrets:
        print("Секретов для этой сессии нет (policy в secrets.toml).")
        return 0
    for s in secrets:
        desc = f" — {s['description']}" if s.get("description") else ""
        confirm = " [confirm]" if s.get("confirm") else ""
        print(f"{s['name']}{desc}{confirm}")
        # host — команда на хосте с его кредами (keyring/gh/git), инъекции нет.
        # inject — значение в env-переменную $<env> (инструменты вроде gh/aws/
        # kubectl читают её сами), а где нужно значение В КОМАНДЕ — плейсхолдеры
        # {{secret}} (в строку, напр. curl -H '... {{secret}}') и {{secret_file}}
        # (во временный файл, напр. ssh -i {{secret_file}}). Подставляет демон —
        # значение к тебе не попадает.
        mode = s.get("mode")
        if mode == "shared":
            # shared — значение ВЫДАётся тебе (dev-ключ, логин/пароль): его можно
            # прочитать/вставить, оно просто хранится в кошельке, не в чате/репо.
            hint = f", env ${s['env']}" if s.get("env") else ""
            print(f"    режим: shared → `wallet get {s['name']}` (значение{hint})")
        elif mode == "inject" and s.get("env"):
            print(f"    режим: inject → env ${s['env']}; в строке — {{{{secret}}}},"
                  " файлом — {{secret_file}}")
        else:
            print("    режим: host (креды хоста: keyring/gh/git)")
        if mode != "shared":
            for pat in s.get("commands", []):
                print(f"    разрешено: {pat}")
    return 0


def cmd_run(cfg: dict, argv: list) -> int:
    if not argv or "--" not in argv:
        die("использование: wallet run <имя> -- <команда...>")
    sep = argv.index("--")
    names, cmd = argv[:sep], argv[sep + 1:]
    if len(names) != 1 or not cmd:
        die("использование: wallet run <имя> -- <команда...>")
    result = call(cfg, "POST", "/run", {"secret": names[0], "cmd": cmd})
    if result.get("stdout"):
        sys.stdout.write(result["stdout"])
        if not result["stdout"].endswith("\n"):
            sys.stdout.write("\n")
    if result.get("stderr"):
        sys.stderr.write(result["stderr"])
        if not result["stderr"].endswith("\n"):
            sys.stderr.write("\n")
    return int(result.get("code", 1))


def cmd_get(cfg: dict, argv: list) -> int:
    """Выдать ЗНАЧЕНИЕ shared-секрета (dev-ключ, логин/пароль). Только для
    секретов с shared=true; host/inject значения не выдаются."""
    if len(argv) != 1:
        die("использование: wallet get <имя>")
    result = call(cfg, "POST", "/get", {"secret": argv[0]})
    sys.stdout.write(result.get("value", ""))
    if not result.get("value", "").endswith("\n"):
        sys.stdout.write("\n")
    return 0


def cmd_env(cfg: dict, argv: list) -> int:
    """Выдать shared-секрет в виде `export ENV=значение` — для eval или .env
    сервиса: eval \"$(wallet env <имя>)\"."""
    if len(argv) != 1:
        die("использование: wallet env <имя>")
    result = call(cfg, "POST", "/get", {"secret": argv[0]})
    env = result.get("env")
    if not env:
        die(f"у секрета «{argv[0]}» не задан env — используй `wallet get {argv[0]}`")
    # Значение в одинарных кавычках с экранированием ' — безопасно для eval.
    val = result.get("value", "").replace("'", "'\\''")
    print(f"export {env}='{val}'")
    return 0


def main() -> int:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(HELP)
        return 0
    cfg = load_config()
    if args[0] == "ls":
        return cmd_ls(cfg)
    if args[0] == "run":
        return cmd_run(cfg, args[1:])
    if args[0] == "get":
        return cmd_get(cfg, args[1:])
    if args[0] == "env":
        return cmd_env(cfg, args[1:])
    die(f"неизвестная команда {args[0]!r} (ls | run | get | env)")


if __name__ == "__main__":
    sys.exit(main())
